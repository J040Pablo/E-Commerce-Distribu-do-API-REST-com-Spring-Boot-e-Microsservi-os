# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_HOST=localhost
DB_PORT=3307
DB_NAME=ecommerce_db
DB_USER=root
DB_USERNAME=root
DB_PASSWORD=change_me_in_production
DB_DIALECT=org.hibernate.dialect.MySQLDialect

# ============================================================
# JWT CONFIGURATION (SECURITY CRITICAL)
# ============================================================
# Generate a strong secret using: openssl rand -base64 32
# For production, use at least 256-bit entropy
JWT_SECRET=your-super-secret-jwt-key-at-least-256-bits-base64-encoded
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ============================================================
# RABBITMQ CONFIGURATION
# ============================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ============================================================
# EUREKA/SERVICE DISCOVERY
# ============================================================
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka

# ============================================================
# APPLICATION ENVIRONMENT
# ============================================================
SPRING_PROFILES_ACTIVE=dev
ENVIRONMENT=development

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# ============================================================
# DOCKER INFRA SECRETS
# ============================================================
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password
MYSQL_DATABASE=ecommerce_db
RABBITMQ_DEFAULT_USER=change_me_rabbitmq_user
RABBITMQ_DEFAULT_PASS=change_me_rabbitmq_password

# ============================================================
# GRAFANA ADMIN CREDENTIALS
# ============================================================
GRAFANA_ADMIN_USER=change_me_grafana_admin_user
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin_password
